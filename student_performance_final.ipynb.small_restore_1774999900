    "    fe_df[\"stress_inverse\"] = 1.0 / (fe_df[\"Stress_Level\"] + 1.0)\n",
    "\n",
    "# 4.1.2 Polynomial (karesel) — seçili kolonlar\n",
    "for col in [c for c in [\"Weekly_Study_Hours\", \"Attendance_Rate\", \"Previous_Scores\"] if c in fe_df.columns]:\n",
    "    fe_df[f\"{col}_sq\"] = fe_df[col] ** 2\n",
    "\n",
    "# 4.1.3 Binning (kategorileştirme)\n",
    "if \"Sleep_Hours\" in fe_df.columns:\n",
    "    fe_df[\"Sleep_Bin\"] = pd.qcut(fe_df[\"Sleep_Hours\"], q=4, labels=[\"Q1_low\", \"Q2_mid\", \"Q3_mid\", \"Q4_high\"])\n",
    "\n",
    "if \"Internet_Usage_Time\" in fe_df.columns:\n",
    "    fe_df[\"Internet_Bin\"] = pd.qcut(fe_df[\"Internet_Usage_Time\"], q=4, labels=[\"Q1_low\", \"Q2_mid\", \"Q3_mid\", \"Q4_high\"])\n",
    "\n",
    "# 4.1.4 Hızlı kontrol\n",
    "new_cols = [c for c in fe_df.columns if c not in clean_df.columns]\n",
    "print(\"✅ Yeni feature sayısı:\", len(new_cols))\n",
    "print(\"Yeni feature örnekleri:\", new_cols[:12])\n",
    "\n",
    "# 4.2 Korelasyon: yeni numeric feature’lar\n",
    "num_fe = fe_df.select_dtypes(include=[np.number])\n",
    "if target_col in num_fe.columns:\n",
    "    corr_fe = num_fe.corr(numeric_only=True)\n",
    "    fig_fe_corr = px.imshow(corr_fe, color_continuous_scale=\"RdBu\", zmin=-1, zmax=1)\n",
    "    show_export(fig_fe_corr, next_fig(\"fe_corr_matrix\"), title=\"4.2.1 Feature Engineering sonrası korelasyon matrisi\")\n",
    "    narrate(\n",
    "        \"FE sonrası korelasyon\",\n",
    "        [\n",
    "            \"Yeni oluşturulan özelliklerin hedefle ve birbirleriyle ilişkisini görürüz.\",\n",
    "            \"Aşırı korelasyonlu yeni feature’lar varsa drop/regularization kararı gündeme gelir.\",\n",
    "        ],\n",
    "    )\n",
    "\n",
    "# 4.2.2 Mutual Information (MI) — kategorikleri hızlı encode ederek\n",
    "X_cols = [c for c in fe_df.columns if c not in [target_col, \"Student_ID\"]]\n",
    "\n",
    "X = fe_df[X_cols].copy()\n",
    "y = fe_df[target_col].astype(float)\n",
    "\n",
    "cat_cols = X.select_dtypes(include=[\"object\", \"category\"]).columns.tolist()\n",
    "num_cols = [c for c in X.columns if c not in cat_cols]\n",
    "\n",
    "# MI için basit encoding: kategorikleri kodla\n",
    "X_mi = X.copy()\n",
    "for c in cat_cols:\n",
    "    X_mi[c] = X_mi[c].astype(\"category\").cat.codes\n",
    "\n",
    "mi = mutual_info_regression(X_mi, y, random_state=RANDOM_STATE)\n",
    "mi_df = pd.DataFrame({\"feature\": X_cols, \"mi\": mi}).sort_values(\"mi\", ascending=False)\n",
    "display(mi_df.head(20))\n",
    "\n",
    "fig_mi = px.bar(mi_df.head(25), x=\"mi\", y=\"feature\", orientation=\"h\", color_discrete_sequence=[\"#6c5ce7\"])\n",
    "show_export(fig_mi, next_fig(\"fe_mutual_info_top\"), title=\"4.2.2 Mutual Information — Top 25\")\n",
    "\n",
    "narrate(\n",
    "    \"Mutual Information (MI)\",\n",
    "    [\n",
    "        \"MI, feature ile hedef arasındaki ‘bilgi’ katkısını ölçer (doğrusal olmak zorunda değildir).\",\n",
    "        \"Top MI feature’lar genellikle model performansını daha çok etkiler ve FE önceliği için kullanılır.\",\n",
    "        \"Bu çıktı, çok sayıda feature içinde en etkili adayları seçmemizi sağlar.\",\n",
    "    ],\n",
    ")\n",
    "\n",
    "# 4.3 Feature tablosunu kaydet\n",
    "FEATURE_PATH = DATA_PROCESSED_DIR / \"student_performance_features.csv\"\n",
    "fe_df.to_csv(FEATURE_PATH, index=False)\n",
    "print(\"✅ Feature tablosu kaydedildi:\", FEATURE_PATH)\n"
