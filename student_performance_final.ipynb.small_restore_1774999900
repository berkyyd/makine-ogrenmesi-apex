    "# 2.2 Target analizi + export\n",
    "\n",
    "target_col = \"Exam_Score\"\n",
    "y = df_raw[target_col].astype(float)\n",
    "\n",
    "stats_summary = pd.Series({\n",
    "    \"mean\": float(y.mean()),\n",
    "    \"median\": float(y.median()),\n",
    "    \"std\": float(y.std(ddof=1)),\n",
    "    \"skew\": float(y.skew()),\n",
    "    \"kurtosis\": float(y.kurtosis()),\n",
    "    \"min\": float(y.min()),\n",
    "    \"max\": float(y.max()),\n",
    "}, name=\"Exam_Score_stats\")\n",
    "\n",
    "display(stats_summary)\n",
    "spacer(10)\n",
    "\n",
    "fig_hist = px.histogram(\n",
    "    df_raw,\n",
    "    x=target_col,\n",
    "    nbins=40,\n",
    "    marginal=\"box\",\n",
    "    opacity=0.88,\n",
    "    color_discrete_sequence=[\"#6c5ce7\"],\n",
    ")\n",
    "show_export(fig_hist, \"01_target_hist_box.html\", title=\"2.2.1 Exam_Score (Histogram + Box)\")\n",
    "narrate(\n",
    "    \"Exam_Score dağılımı\",\n",
    "    [\n",
    "        \"Notların hangi aralıkta yoğunlaştığını ve dağılımın tek/çok tepeli olup olmadığını görürüz.\",\n",
    "        \"Box kısmı uç değer (outlier) sinyali verir: çok uzun kuyruklar varsa model hataları artabilir.\",\n",
    "        \"Bu çıktı, hangi metriklerin (RMSE/MAE/MAPE) daha anlamlı olacağı ve gerekirse robust yaklaşım gerekip gerekmediği için bir erken uyarıdır.\",\n",
    "    ],\n",
    "    note=\"Sonraki adım: normalite ve percentile davranışına bakarak (Q-Q, percentiles) preprocessing kararlarını netleştirmek.\",\n",
    ")\n",
    "\n",
    "fig_violin = px.violin(\n",
    "    df_raw,\n",
    "    y=target_col,\n",
    "    box=True,\n",
    "    points=\"all\",\n",
    "    color_discrete_sequence=[\"#00b894\"],\n",
    ")\n",
    "show_export(fig_violin, \"02_target_violin.html\", title=\"2.2.2 Exam_Score (Violin + Box + Points)\")\n",
    "narrate(\n",
    "    \"Exam_Score yoğunluğu (violin)\",\n",
    "    [\n",
    "        \"Yoğunluk şekli (kabarıklık/ince kuyruk) hedefin ‘tipik’ değerlerini gösterir.\",\n",
    "        \"Noktalar, örneklerin hedef üzerinde nasıl dağıldığını ve ekstrem değerlerin nerede toplandığını görmemizi sağlar.\",\n",
    "        \"Bu çıktı, target’ın transform’a (örn. log) ihtiyaç duyup duymadığına dair sinyal üretir.\",\n",
    "    ],\n",
    ")\n",
    "\n",
    "# Q-Q plot\n",
    "qq = stats.probplot(y, dist=\"norm\")\n",
    "theo = qq[0][0]\n",
    "ordered = qq[0][1]\n",
    "slope, intercept, r = qq[1]\n",
    "\n",
    "fig_qq = go.Figure()\n",
    "fig_qq.add_trace(go.Scatter(\n",
    "    x=theo,\n",
    "    y=ordered,\n",
    "    mode=\"markers\",\n",
    "    name=\"Sample quantiles\",\n",
    "    marker=dict(color=\"#0984e3\", size=7, opacity=0.85),\n",
    "))\n",
    "line_x = np.array([theo.min(), theo.max()])\n",
    "line_y = intercept + slope * line_x\n",
    "fig_qq.add_trace(go.Scatter(\n",
    "    x=line_x,\n",
    "    y=line_y,\n",
    "    mode=\"lines\",\n",
    "    name=\"Reference line\",\n",
    "    line=dict(color=\"#d63031\", width=3),\n",
    "))\n",
    "fig_qq.update_layout(xaxis_title=\"Theoretical quantiles (Normal)\", yaxis_title=\"Ordered values (Exam_Score)\")\n",
    "show_export(fig_qq, \"03_target_qqplot.html\", title=f\"2.2.3 Q-Q Plot (Normal) — r={r:.3f}\")\n",
    "narrate(\n",
    "    \"Normalite kontrolü (Q-Q)\",\n",
    "    [\n",
    "        \"Noktalar referans çizgisinden sistematik sapıyorsa hedef dağılımı normalden farklıdır.\",\n",
    "        \"Normalite sapması bazı modellerde (özellikle lineer varsayımlı yaklaşımlarda) residual davranışını etkileyebilir.\",\n",
    "        \"Bu çıktı, ‘mutlaka dönüşüm’ demek değildir; ama metrik seçimi ve model ailesi kararını bilinçli almamızı sağlar.\",\n",
    "    ],\n",
    ")\n",
    "\n",
    "# Percentiles\n",
    "percentiles = [0.01, 0.05, 0.10, 0.25, 0.50, 0.75, 0.90, 0.95, 0.99]\n",
    "q = y.quantile(percentiles)\n",
    "q_df = pd.DataFrame({\"percentile\": [int(p*100) for p in percentiles], \"value\": q.values})\n",
    "display(q_df)\n",
    "spacer(10)\n",
    "\n",
    "fig_pct = px.line(\n",
    "    q_df,\n",
    "    x=\"percentile\",\n",
    "    y=\"value\",\n",
    "    markers=True,\n",
    "    color_discrete_sequence=[\"#fdcb6e\"],\n",
