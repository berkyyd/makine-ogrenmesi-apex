    "# 5 Modeling & Evaluation: 12+ model, CV, tuning, diagnostics, model kaydı\n",
    "\n",
    "from dataclasses import dataclass\n",
    "\n",
    "from sklearn.metrics import make_scorer\n",
    "\n",
    "from sklearn.model_selection import KFold, GridSearchCV, train_test_split, cross_validate\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.preprocessing import OneHotEncoder, StandardScaler\n",
    "from sklearn.impute import SimpleImputer\n",
    "\n",
    "from sklearn.linear_model import LinearRegression, Ridge, Lasso, ElasticNet\n",
    "from sklearn.svm import SVR\n",
    "from sklearn.neighbors import KNeighborsRegressor\n",
    "from sklearn.tree import DecisionTreeRegressor\n",
    "from sklearn.ensemble import RandomForestRegressor, GradientBoostingRegressor, AdaBoostRegressor, ExtraTreesRegressor\n",
    "\n",
    "\n",
    "# Veri: feature engineering sonrası tablo\n",
    "model_df = fe_df.copy()\n",
    "\n",
    "# X / y\n",
    "X_cols = [c for c in model_df.columns if c not in [target_col, \"Student_ID\"]]\n",
    "X = model_df[X_cols].copy()\n",
    "y = model_df[target_col].astype(float)\n",
    "\n",
    "cat_cols = X.select_dtypes(include=[\"object\", \"category\"]).columns.tolist()\n",
    "num_cols = [c for c in X.columns if c not in cat_cols]\n",
    "\n",
    "# Preprocess\n",
    "numeric_tf = Pipeline(steps=[\n",
    "    (\"imputer\", SimpleImputer(strategy=\"median\")),\n",
    "    (\"scaler\", StandardScaler()),\n",
    "])\n",
    "\n",
    "categorical_tf = Pipeline(steps=[\n",
    "    (\"imputer\", SimpleImputer(strategy=\"most_frequent\")),\n",
    "    (\"onehot\", OneHotEncoder(handle_unknown=\"ignore\", sparse_output=False)),\n",
    "])\n",
    "\n",
    "preprocess = ColumnTransformer(\n",
    "    transformers=[\n",
    "        (\"num\", numeric_tf, num_cols),\n",
    "        (\"cat\", categorical_tf, cat_cols),\n",
    "    ],\n",
    "    remainder=\"drop\",\n",
    ")\n",
    "\n",
    "# MAPE scorer\n",
    "\n",
    "def mape(y_true, y_pred):\n",
    "    y_true = np.asarray(y_true)\n",
    "    y_pred = np.asarray(y_pred)\n",
    "    denom = np.clip(np.abs(y_true), 1e-6, None)\n",
    "    return float(np.mean(np.abs((y_true - y_pred) / denom)))\n",
    "\n",
    "mape_scorer = make_scorer(mape, greater_is_better=False)\n",
    "\n",
    "scoring = {\n",
    "    \"r2\": \"r2\",\n",
    "    \"rmse\": \"neg_root_mean_squared_error\",\n",
    "    \"mae\": \"neg_mean_absolute_error\",\n",
    "    \"mape\": mape_scorer,\n",
    "}\n",
    "\n",
    "cv = KFold(n_splits=5, shuffle=True, random_state=RANDOM_STATE)\n",
    "\n",
    "@dataclass\n",
    "class ModelSpec:\n",
    "    name: str\n",
    "    estimator: object\n",
    "    needs_scaling: bool = True\n",
    "\n",
    "models = [\n",
    "    ModelSpec(\"LinearRegression\", LinearRegression()),\n",
    "    ModelSpec(\"Ridge\", Ridge(random_state=RANDOM_STATE)),\n",
    "    ModelSpec(\"Lasso\", Lasso(random_state=RANDOM_STATE, max_iter=5000)),\n",
    "    ModelSpec(\"ElasticNet\", ElasticNet(random_state=RANDOM_STATE, max_iter=5000)),\n",
    "    ModelSpec(\"SVR_RBF\", SVR(kernel=\"rbf\")),\n",
    "    ModelSpec(\"KNN\", KNeighborsRegressor()),\n",
    "    ModelSpec(\"DecisionTree\", DecisionTreeRegressor(random_state=RANDOM_STATE), needs_scaling=False),\n",
    "    ModelSpec(\"RandomForest\", RandomForestRegressor(random_state=RANDOM_STATE, n_estimators=400), needs_scaling=False),\n",
    "    ModelSpec(\"ExtraTrees\", ExtraTreesRegressor(random_state=RANDOM_STATE, n_estimators=400), needs_scaling=False),\n",
    "    ModelSpec(\"GradientBoosting\", GradientBoostingRegressor(random_state=RANDOM_STATE), needs_scaling=False),\n",
    "    ModelSpec(\"AdaBoost\", AdaBoostRegressor(random_state=RANDOM_STATE), needs_scaling=False),\n",
    "]\n",
    "\n",
    "# 12+ koşulu için 1 model daha\n",
    "models.append(ModelSpec(\"Ridge_robust\", Ridge(random_state=RANDOM_STATE, alpha=10.0)))\n",
    "\n",
    "# Train/test\n",
    "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=RANDOM_STATE)\n",
    "\n",
    "results = []\n",
    "cv_distributions = []\n",
    "\n",
    "for spec in models:\n",
    "    # ağaç modellerinde scaler etkisiz; ama pipeline basitliği için scaler bırakılabilir\n",
    "    pipe = Pipeline(steps=[(\"preprocess\", preprocess), (\"model\", spec.estimator)])\n",
    "\n",
    "    cv_out = cross_validate(\n",
    "        pipe,\n",
    "        X_train,\n",
    "        y_train,\n",
    "        cv=cv,\n",
    "        scoring=scoring,\n",
    "        n_jobs=1,\n",
    "        return_train_score=False,\n",
    "    )\n",
    "\n",
    "    r2 = float(np.mean(cv_out[\"test_r2\"]))\n",
    "    rmse = float(-np.mean(cv_out[\"test_rmse\"]))\n",
    "    mae = float(-np.mean(cv_out[\"test_mae\"]))\n",
    "    mape_val = float(-np.mean(cv_out[\"test_mape\"]))\n",
    "\n",
    "    results.append({\n",
    "        \"model\": spec.name,\n",
    "        \"cv_r2\": r2,\n",
    "        \"cv_rmse\": rmse,\n",
    "        \"cv_mae\": mae,\n",
    "        \"cv_mape\": mape_val,\n",
    "        \"cv_rmse_std\": float(np.std(-cv_out[\"test_rmse\"], ddof=1)),\n",
    "    })\n",
    "\n",
    "    # CV dağılımı (boxplot için)\n",
    "    for v in -cv_out[\"test_rmse\"]:\n",
    "        cv_distributions.append({\"model\": spec.name, \"rmse\": float(v)})\n",
    "\n",
    "results_df = pd.DataFrame(results).sort_values(\"cv_rmse\", ascending=True)\n",
    "display(results_df)\n",
    "\n",
    "# Model karşılaştırma grafikleri\n",
    "fig_rmse = px.bar(\n",
    "    results_df,\n",
    "    x=\"model\",\n",
    "    y=\"cv_rmse\",\n",
    "    color=\"cv_r2\",\n",
    "    color_continuous_scale=\"Viridis\",\n",
    "    labels={\"cv_rmse\": \"CV RMSE (lower better)\", \"cv_r2\": \"CV R² (higher better)\"},\n",
    ")\n",
    "fig_rmse.update_layout(xaxis_tickangle=25)\n",
    "show_export(fig_rmse, next_fig(\"model_cv_rmse_r2\"), title=\"5.1.1 Model Karşılaştırma — CV RMSE (renk=R²)\")\n",
    "\n",
    "narrate(\n",
    "    \"Model karşılaştırma (CV)\",\n",
    "    [\n",
    "        \"Her model için 5-fold CV ile genelleme performansını kıyaslarız (tek split şansa bağlı kalmaz).\",\n",
    "        \"RMSE düşük olan modeller hedefi daha isabetli tahmin eder; renk (R²) açıklama gücünü destekler.\",\n",
    "        \"Bu çıktı, tuning’e hangi 2–3 modeli taşıyacağımızı seçmemizi sağlar.\",\n",
    "    ],\n",
    ")\n",
    "\n",
    "cv_box = pd.DataFrame(cv_distributions)\n",
    "fig_box = px.box(cv_box, x=\"model\", y=\"rmse\", points=\"all\", color_discrete_sequence=[\"#6c5ce7\"])\n",
    "fig_box.update_layout(xaxis_tickangle=25)\n",
    "show_export(fig_box, next_fig(\"model_cv_rmse_boxplot\"), title=\"5.2.1 5-Fold CV Stabilite — RMSE Boxplot\")\n",
    "\n",
    "narrate(\n",
    "    \"CV stabilitesi (boxplot)\",\n",
    "    [\n",
    "        \"Kutular dar ise model farklı fold’larda benzer performans verir (stabil).\",\n",
    "        \"Kutular geniş ise model veri alt örneklemlerine duyarlıdır (genelleme riski).\",\n",
    "        \"Bu çıktı overfitting riskini erken görmemizi sağlar ve tuning/model seçimini etkiler.\",\n",
    "    ],\n",
    ")\n",
    "\n",
    "# Tuning: en iyi 3 model\n",
    "candidates = results_df.head(3)[\"model\"].tolist()\n",
    "\n",
    "spec_map = {m.name: m for m in models}\n",
    "\n",
    "def param_grid_for(name: str):\n",
    "    if name.startswith(\"Ridge\"):\n",
    "        return {\"model__alpha\": [0.1, 1.0, 10.0, 50.0]}\n",
    "    if name == \"Lasso\":\n",
    "        return {\"model__alpha\": [0.0005, 0.001, 0.01, 0.05, 0.1]}\n",
    "    if name == \"ElasticNet\":\n",
    "        return {\"model__alpha\": [0.001, 0.01, 0.1, 1.0], \"model__l1_ratio\": [0.2, 0.5, 0.8]}\n",
    "    if name == \"SVR_RBF\":\n",
    "        return {\"model__C\": [1.0, 5.0, 10.0], \"model__gamma\": [\"scale\", \"auto\"]}\n",
    "    if name == \"KNN\":\n",
    "        return {\"model__n_neighbors\": [3, 5, 9, 15]}\n",
    "    if name == \"RandomForest\":\n",
    "        return {\"model__max_depth\": [None, 6, 10], \"model__min_samples_split\": [2, 5, 10]}\n",
    "    if name == \"ExtraTrees\":\n",
    "        return {\"model__max_depth\": [None, 6, 10], \"model__min_samples_split\": [2, 5, 10]}\n",
    "    if name == \"GradientBoosting\":\n",
    "        return {\"model__n_estimators\": [200, 400], \"model__learning_rate\": [0.05, 0.1], \"model__max_depth\": [2, 3]}\n",
    "    if name == \"AdaBoost\":\n",
    "        return {\"model__n_estimators\": [200, 400], \"model__learning_rate\": [0.05, 0.1, 0.2]}\n",
    "    if name == \"DecisionTree\":\n",
    "        return {\"model__max_depth\": [None, 4, 6, 10], \"model__min_samples_split\": [2, 5, 10]}\n",
    "    return {}\n",
    "\n",
    "best_models = []\n",
    "for name in candidates:\n",
    "    spec = spec_map[name]\n",
    "    grid = param_grid_for(name)\n",
    "    pipe = Pipeline(steps=[(\"preprocess\", preprocess), (\"model\", spec.estimator)])\n",
    "\n",
    "    if not grid:\n",
    "        # grid yoksa direkt aday\n",
    "        pipe.fit(X_train, y_train)\n",
    "        y_pred = pipe.predict(X_test)\n",
    "        rmse = float(np.sqrt(mean_squared_error(y_test, y_pred)))\n",
    "        mae = float(mean_absolute_error(y_test, y_pred))\n",
    "        r2 = float(r2_score(y_test, y_pred))\n",
    "        mape_val = float(mape(y_test, y_pred))\n",
    "        best_models.append({\"model\": name, \"best_params\": {}, \"test_rmse\": rmse, \"test_mae\": mae, \"test_r2\": r2, \"test_mape\": mape_val, \"estimator\": pipe})\n",
    "        continue\n",
    "\n",
    "    gs = GridSearchCV(\n",
    "        pipe,\n",
    "        param_grid=grid,\n",
    "        scoring=\"neg_root_mean_squared_error\",\n",
    "        cv=cv,\n",
    "        n_jobs=1,\n",
    "    )\n",
    "    gs.fit(X_train, y_train)\n",
    "\n",
    "    best_est = gs.best_estimator_\n",
    "    y_pred = best_est.predict(X_test)\n",
    "\n",
    "    rmse = float(np.sqrt(mean_squared_error(y_test, y_pred)))\n",
    "    mae = float(mean_absolute_error(y_test, y_pred))\n",
    "    r2 = float(r2_score(y_test, y_pred))\n",
    "    mape_val = float(mape(y_test, y_pred))\n",
    "\n",
    "    best_models.append({\n",
    "        \"model\": name,\n",
    "        \"best_params\": gs.best_params_,\n",
    "        \"test_rmse\": rmse,\n",
    "        \"test_mae\": mae,\n",
    "        \"test_r2\": r2,\n",
    "        \"test_mape\": mape_val,\n",
    "        \"estimator\": best_est,\n",
    "    })\n",
    "\n",
    "best_df = pd.DataFrame([{k: v for k, v in d.items() if k != \"estimator\"} for d in best_models]).sort_values(\"test_rmse\")\n",
    "display(best_df)\n",
    "\n",
    "fig_best = px.bar(\n",
    "    best_df,\n",
    "    x=\"model\",\n",
    "    y=\"test_rmse\",\n",
    "    color=\"test_r2\",\n",
    "    color_continuous_scale=\"Viridis\",\n",
    "    labels={\"test_rmse\": \"Test RMSE\", \"test_r2\": \"Test R²\"},\n",
    ")\n",
    "show_export(fig_best, next_fig(\"tuned_models_test_rmse\"), title=\"5.2.2 Tuned adaylar — Test RMSE (renk=R²)\")\n",
    "\n",
    "narrate(\n",
    "    \"Tuning sonrası test performansı\",\n",
    "    [\n",
    "        \"GridSearchCV ile model hiperparametrelerini optimize ederek test performansını iyileştirmeyi hedefleriz.\",\n",
    "        \"Test RMSE, gerçek dünya genelleme hatasını temsil eder; tuning faydasını burada görürüz.\",\n",
    "        \"Bu çıktı final modeli seçmemizi sağlar.\",\n",
    "    ],\n",
    "    note=\"GridSearchCV bir hiperparametre optimizasyonudur; modelin en optimal iyiliğe ulaşması için ayarları tarar.\",\n",
    ")\n",
    "\n",
    "# Final model seçimi (test RMSE en düşük)\n",
    "best_row = best_models[best_df.index[0]] if len(best_df) else best_models[0]\n",
    "final_model = best_row[\"estimator\"]\n",
    "final_name = best_row[\"model\"]\n",
    "\n",
    "# Diagnostics\n",
    "final_pred = final_model.predict(X_test)\n",
    "\n",
    "scatter_df = pd.DataFrame({\"y_true\": y_test.values, \"y_pred\": final_pred})\n",
    "fig_sc = px.scatter(scatter_df, x=\"y_true\", y=\"y_pred\", opacity=0.6, color_discrete_sequence=[\"#0984e3\"])\n",
    "fig_sc.add_trace(go.Scatter(x=[scatter_df.y_true.min(), scatter_df.y_true.max()], y=[scatter_df.y_true.min(), scatter_df.y_true.max()], mode=\"lines\", name=\"ideal\", line=dict(color=\"#ef4444\", width=3)))\n",
    "show_export(fig_sc, next_fig(\"diagnostic_true_vs_pred\"), title=f\"5.2.3 y_true vs y_pred — {final_name}\")\n",
    "\n",
    "resid_df = pd.DataFrame({\"y_pred\": final_pred, \"residual\": (y_test.values - final_pred)})\n",
    "fig_res = px.scatter(resid_df, x=\"y_pred\", y=\"residual\", opacity=0.6, color_discrete_sequence=[\"#6c5ce7\"])\n",
    "fig_res.add_hline(y=0, line_width=3, line_color=\"#ef4444\")\n",
    "show_export(fig_res, next_fig(\"diagnostic_residuals\"), title=f\"5.2.4 Residual Plot — {final_name}\")\n",
    "\n",
    "narrate(\n",
    "    \"Model diagnostikleri\",\n",
    "    [\n",
    "        \"y_true vs y_pred grafiğinde noktalar diyagonale yakınsa tahminler tutarlıdır.\",\n",
    "        \"Residual plot’ta kalıp bir desen varsa (örn. eğrilik), model bazı bölgelerde sistematik hata yapıyor demektir.\",\n",
    "        \"Bu çıktı, ‘model hangi durumlarda yanılıyor?’ sorusuna cevap verir ve FE için geri beslemedir.\",\n",
    "    ],\n",
    ")\n",
    "\n",
    "# Model kaydı\n",
    "MODEL_PATH = MODELS_DIR / \"best_model.pkl\"\n",
    "joblib.dump(final_model, MODEL_PATH)\n",
    "print(\"✅ Final model kaydedildi:\", MODEL_PATH)\n",
    "print(\"Final model:\", final_name)\n"
   ]
  }
